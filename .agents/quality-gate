#!/usr/bin/env bash

set -euo pipefail

echo "[markbase] running repo quality gate"
test -x .venv/bin/python || { echo "[markbase] missing .venv/bin/python" >&2; exit 2; }
bash -n start.sh
bash -n run-service.sh
.venv/bin/python -m py_compile app.py ingest.py queue_worker.py
.venv/bin/python -m unittest discover -s tests -p 'test_*.py'
